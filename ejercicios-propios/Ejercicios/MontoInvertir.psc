Algoritmo MontoInvertir
	Definir mInvertir, mFin, interes Como Real;
	Escribir "Ingrese el monto a invertir: "
	Leer mInventir; 
	
	interes = (mInventir * 0.03) * 3;
	mFin = mInventir + interes; 
	
	Escribir "El interes obtenido es de Q/ ", interes; 
	Escribir "El monto final obtenido es de Q/ " mFin; 
	
FinAlgoritmo
